{
  "name": "shuimo-theme",
  "displayName": "水墨 Theme",
  "description": "水墨主题系列：包含「竹简」「竹简墨夜」棕色系列、「水墨丹青」「水墨夜境」水墨风系列与「月涌大江流」深蓝夜江系列，古韵雅致，适合喜欢自然风格的开发者。",
  "version": "1.3.0",
  "publisher": "wangx123",
  "icon": "logo.png",
  "scripts": {
    "build": "npx @vscode/vsce package"
  },
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Themes"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/wangx7/bamboo-scroll-theme.git"
  },
  "contributes": {
    "themes": [
      {
        "label": "竹简",
        "uiTheme": "vs",
        "path": "./themes/bamboo-scroll-light-color-theme.json"
      },
      {
        "label": "水墨丹青",
        "uiTheme": "vs",
        "path": "./themes/ink-wash-light-color-theme.json"
      },
      {
        "label": "竹简墨夜",
        "uiTheme": "vs-dark",
        "path": "./themes/bamboo-scroll-dark-color-theme.json"
      },
      {
        "label": "月涌大江流",
        "uiTheme": "vs-dark",
        "path": "./themes/moon-river-dark-color-theme.json"
      }
    ]
  }
}